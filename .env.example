SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inp2ZG56dGVwZHZua2NrYnhnbHR6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM3OTE0OTAsImV4cCI6MjA5OTM2NzQ5MH0.BmtKL_72AXyTAproFfgIkjW_Z66z9NAnJs5cXpEbjao
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inp2ZG56dGVwZHZua2NrYnhnbHR6Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4Mzc5MTQ5MCwiZXhwIjoyMDk5MzY3NDkwfQ._j1J9TYQsm69dZjD1he5c1f4Oh15K68e72t6-k_Vhtk

