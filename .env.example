DATABASE_URL=postgresql://postgres:[password]@db.zvdnztepdvnkckbxgltz.supabase.co:5432/postgres

# App config
LINKEDIN_API_VERSION=202501
POST_TIME=09:00
COMPANY_NAME=Your Company
COMPANY_CONTEXT="We build AI-powered software for small businesses."
SECRET_KEY=change-me-to-a-random-secret-with-at-least-32-chars
ENVIRONMENT=development
FORCE_HTTPS=false
APP_VERSION=1.0.0

# Security & sessions
WTF_CSRF_ENABLED=true
WTF_CSRF_TIME_LIMIT=3600
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=86400
MAX_CONTENT_LENGTH=2097152

# Token encryption (recommended in production; generate with Fernet.generate_key())
ENCRYPTION_KEY=

# Optional admin seeding. Set both to create an admin on startup.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Background scheduler. Disable in serverless/web containers; run as a separate process.
SCHEDULER_ENABLED=true

# Rate limiting. Use Redis in production when running multiple workers,
# otherwise per-process memory storage will apply limits independently.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URI=memory://
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379
