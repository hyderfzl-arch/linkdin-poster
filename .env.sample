# Flask Configuration
# Must be at least 32 characters long when ENVIRONMENT=production.
SECRET_KEY=your-secret-key-must-be-at-least-32-characters-long
FLASK_ENV=development

# LinkedIn API Credentials
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:5000/callback
LINKEDIN_OAUTH_SCOPES=openid profile email w_member_social

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key

# Database Configuration
DATABASE_URL=sqlite:///app.db  # For development
# DATABASE_URL=postgresql://user:password@localhost/dbname  # For production

# Supabase (optional)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Security Settings
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5

# Production Settings
FORCE_HTTPS=true
ENVIRONMENT=production

# Token encryption (recommended in production; generate with cryptography.fernet.Fernet.generate_key())
ENCRYPTION_KEY=

# Optional admin seeding. Set both to create an admin on startup.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Background scheduler (disable in serverless/web containers)
SCHEDULER_ENABLED=true

# Rate limiting (use Redis URL in production, e.g. redis://localhost:6379)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URI=memory://
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379

# Max HTTP body size in bytes (default 2 MB)
MAX_CONTENT_LENGTH=2097152